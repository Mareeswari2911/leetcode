class Solution {
    public int minSteps(String s, String t) {
        int[] freq=new int[26];
        for(char ch:s.toCharArray())
        {
            freq[ch-'a']++;
        }
        for(char ch:t.toCharArray())
        {
            freq[ch-'a']--;
        }
        int step=0;
        for(int val:freq)
        {
            if(val>0)
            {
                step=step+val;
            }
        }
        return step;
    }
}
