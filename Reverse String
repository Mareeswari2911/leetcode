class Solution {
    public void reverseString(char[] s) {
        int l=s.length;
        char[] arr=new char[l];
        int j=0;
        for(int i=l-1;i>=0;i--)
        {
            arr[j]=s[i];
            j++;
        }
        for(int i=0;i<l;i++)
        {
            s[i]=arr[i];
        }
    }
}
