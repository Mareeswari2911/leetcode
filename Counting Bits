class Solution {
    public int[] countBits(int n) {
        int[] arr=new int[n+1];
        for(int i=0;i<=n;i++)
        {
            int k=i;
            int sum=0;
            while(k>0)
            {
                int bit=k%2;
                if(bit==1)
                {
                    sum++;
                }
                k=k/2;
            }
            arr[i]=sum;
        }
        return arr;
    }
}
