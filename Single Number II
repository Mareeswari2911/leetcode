class Solution {
    public int singleNumber(int[] nums) {
        HashMap<Integer,Integer> h=new HashMap<>();
        for(int i:nums)
        {
            h.put(i,h.getOrDefault(i,0)+1);
        }
        for (Map.Entry<Integer, Integer> entry : h.entrySet()) {
            if(entry.getValue()!=3)
            {
                return entry.getKey();
            }
        }
        return 0;
    }
}
